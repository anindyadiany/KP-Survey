@{
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    bool isResponsesActive = currentAction != null && currentAction.Contains("Responses");
    bool isEditActive = currentAction != null && currentAction.Contains("EditSurvey");

    // For Responses tab, detect which sub-tab is active from query string
    var currentTab = Context.Request.Query["tab"].ToString();
    bool isResponsesWalkIn = isResponsesActive && currentTab == "walkin";
    bool isResponsesOnline = isResponsesActive && currentTab != "walkin";
}

<aside class="sidebar-container">
    <div class="sidebar-logo-wrapper" style="padding: 20px 0;">
        <img src="~/assets/pertaminalogo.png" style="width: 140px;" alt="Logo"> 
    </div>
    <nav style="width: 100%;">

        <a href="@Url.Action("Index", "Dashboard")" class="nav-item @(currentAction == "Index" ? "active" : "")">
            <i class="bi bi-house-door-fill" style="margin-right:12px;"></i><span>Home</span>
        </a>

        @* Edit Survey Group *@
        <div class="nav-group">
            <a href="@Url.Action("EditSurveyOnline", "Dashboard")" class="nav-item @(isEditActive ? "active" : "")">
                <i class="bi bi-pencil-square" style="margin-right:12px;"></i><span>Edit Survey</span>
            </a>
            @if (isEditActive) {
                <div class="sub-nav" style="padding-left: 55px; display: flex; flex-direction: column; gap: 15px; margin: 15px 0 25px 0;">
                    <a href="@Url.Action("EditSurveyWalkIn", "Dashboard")" 
                       style="text-decoration: none; font-size: 1rem; 
                              color: @(currentAction == "EditSurveyWalkIn" ? "#2a408e" : "#888"); 
                              font-weight: 700;">
                        Walk In
                    </a>
                    <a href="@Url.Action("EditSurveyOnline", "Dashboard")" 
                       style="text-decoration: none; font-size: 1rem; 
                              color: @(currentAction == "EditSurveyOnline" ? "#2a408e" : "#888"); 
                              font-weight: 700;">
                        Online
                    </a>
                </div>
            }
        </div>

        @* Responses Group *@
        <div class="nav-group">
            <a href="@Url.Action("Responses", "Dashboard", new { tab = "online" })" class="nav-item @(isResponsesActive ? "active" : "")">
                <i class="bi bi-archive" style="margin-right:12px;"></i><span>Responses</span>
            </a>
            @if (isResponsesActive) {
                <div class="sub-nav" style="padding-left: 55px; display: flex; flex-direction: column; gap: 15px; margin: 15px 0 25px 0;">
                    <a href="@Url.Action("Responses", "Dashboard", new { tab = "walkin" })"
                       style="text-decoration: none; font-size: 1rem;
                              color: @(isResponsesWalkIn ? "#2a408e" : "#888");
                              font-weight: 700;">
                        Walk In
                    </a>
                    <a href="@Url.Action("Responses", "Dashboard", new { tab = "online" })"
                       style="text-decoration: none; font-size: 1rem;
                              color: @(isResponsesOnline ? "#2a408e" : "#888");
                              font-weight: 700;">
                        Online
                    </a>
                </div>
            }
        </div>

        <a href="@Url.Action("EditTeknisi", "Dashboard")" class="nav-item @(currentAction == "EditTeknisi" ? "active" : "")">
            <i class="bi bi-people" style="margin-right:12px;"></i><span>Edit Teknisi</span>
        </a>

        <a href="@Url.Action("User", "Dashboard")" class="nav-item @(currentAction == "User" ? "active" : "")">
            <i class="bi bi-person" style="margin-right:12px;"></i><span>User</span>
        </a>

    </nav>
</aside>
