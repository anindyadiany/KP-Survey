@model (List<SurveyApp.Models.Technician> Technicians, Dictionary<int, double> NpsScores, string Title)

@if (Model.Technicians.Any())
{
    <div class="dashboard-card" style="margin-bottom:24px;">
        <h2 style="font-size:1.2rem; font-weight:800; color:#111; margin:0 0 20px 0;">@Model.Title</h2>
        <table style="width:100%; border-collapse:collapse;">
            <thead>
                <tr style="border-bottom:2px solid rgba(0,0,0,0.07); text-align:left; font-size:0.78rem; color:#888; text-transform:uppercase; letter-spacing:0.05em;">
                    <th style="padding:10px 14px;">Rank</th>
                    <th style="padding:10px 14px;">Teknisi</th>
                    <th style="padding:10px 14px; text-align:center;">Avg Score</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var sortedTechs = Model.Technicians
                        .OrderByDescending(t => Model.NpsScores.ContainsKey(t.id) ? Model.NpsScores[t.id] : 0)
                        .ToList();
                }
                @foreach (var (tech, idx) in sortedTechs.Select((t, i) => (t, i)))
                {
                    var score = Model.NpsScores.ContainsKey(tech.id) ? Model.NpsScores[tech.id] : 0;
                    var initials = string.IsNullOrEmpty(tech.name) ? "?" : tech.name.Substring(0, 1).ToUpper();
                    var isPromoter = score >= 9;
                    var isPassive  = score >= 7 && score < 9;
                    var badgeColor = isPromoter ? "#27ae60" : isPassive ? "#f5a623" : "#e74c3c";
                    var badgeBg    = isPromoter ? "rgba(39,174,96,0.12)" : isPassive ? "rgba(245,166,35,0.12)" : "rgba(231,76,60,0.12)";

                    <tr style="border-bottom:1px solid rgba(0,0,0,0.05);">
                        <td style="padding:13px 14px; font-weight:700; color:#555;">@(idx + 1)</td>
                        <td style="padding:13px 14px;">
                            <div style="display:flex; align-items:center; gap:10px;">
                                @if (!string.IsNullOrEmpty(tech.photo_path))
                                {
                                    <img src="~/assets/foto_teknisi/@tech.photo_path"
                                         style="width:34px; height:34px; border-radius:50%; object-fit:cover; border:1px solid rgba(0,0,0,0.08);"
                                         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                    <div style="width:34px; height:34px; border-radius:50%; background:linear-gradient(135deg,#2a408e,#4a60ae); color:white; display:none; align-items:center; justify-content:center; font-weight:800; font-size:13px; flex-shrink:0;">@initials</div>
                                }
                                else
                                {
                                    <div style="width:34px; height:34px; border-radius:50%; background:linear-gradient(135deg,#2a408e,#4a60ae); color:white; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:13px; flex-shrink:0;">@initials</div>
                                }
                                <span style="font-weight:700; color:#111;">@tech.name</span>
                            </div>
                        </td>
                        <td style="padding:13px 14px; text-align:center;">
                            <span style="padding:4px 14px; border-radius:20px; font-weight:800; font-size:0.9rem; display:inline-block; background:@badgeBg; color:@badgeColor; border:1px solid @badgeColor;">
                                @score.ToString("0.0")
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
