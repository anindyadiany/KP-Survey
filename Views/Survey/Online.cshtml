@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Survey Layanan IT - Online</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <div class="survey-container">
        <div class="progress-track" aria-hidden="true">
            <div class="progress-fill progress-fill-start"></div>
        </div>

        <h1 class="survey-title">Survey Kepuasan Layanan IT</h1>

        <div class="question-group">
            <p class="question-text">Secara keseluruhan, seberapa puas Anda dengan layanan IT yang diberikan?</p>
            <div class="rating-scale">
                <span class="scale-label">Sangat tidak puas</span>
                <div class="rating-number" onclick="highlight(this)">1</div>
                <div class="rating-number" onclick="highlight(this)">2</div>
                <div class="rating-number" onclick="highlight(this)">3</div>
                <div class="rating-number" onclick="highlight(this)">4</div>
                <div class="rating-number" onclick="highlight(this)">5</div>
                <span class="scale-label">Sangat puas</span>
            </div>
        </div>

        <div class="question-group">
            <p class="question-text">Seberapa puas Anda dengan penyelesaian masalah TI Anda?</p>
            <div class="rating-scale">
                <span class="scale-label">Sangat tidak puas</span>
                <div class="rating-number" onclick="highlight(this)">1</div>
                <div class="rating-number" onclick="highlight(this)">2</div>
                <div class="rating-number" onclick="highlight(this)">3</div>
                <div class="rating-number" onclick="highlight(this)">4</div>
                <div class="rating-number" onclick="highlight(this)">5</div>
                <span class="scale-label">Sangat puas</span>
            </div>
        </div>

        <div class="question-group">
            <p class="question-text">Seberapa puas Anda dengan profesionalisme staf TI?</p>
            <div class="rating-scale">
                <span class="scale-label">Sangat tidak puas</span>
                <div class="rating-number" onclick="highlight(this)">1</div>
                <div class="rating-number" onclick="highlight(this)">2</div>
                <div class="rating-number" onclick="highlight(this)">3</div>
                <div class="rating-number" onclick="highlight(this)">4</div>
                <div class="rating-number" onclick="highlight(this)">5</div>
                <span class="scale-label">Sangat puas</span>
            </div>
        </div>

        <div class="question-group">
            <p class="question-text">Seberapa puas Anda dengan kejelasan komunikasi selama proses dukungan berlangsung?</p>
            <div class="rating-scale">
                <span class="scale-label">Sangat tidak puas</span>
                <div class="rating-number" onclick="highlight(this)">1</div>
                <div class="rating-number" onclick="highlight(this)">2</div>
                <div class="rating-number" onclick="highlight(this)">3</div>
                <div class="rating-number" onclick="highlight(this)">4</div>
                <div class="rating-number" onclick="highlight(this)">5</div>
                <span class="scale-label">Sangat puas</span>
            </div>
        </div>

        <div class="question-group">
            <p class="question-text">Secara keseluruhan, seberapa puas Anda dengan layanan TI yang diberikan?</p>
            <div class="rating-scale">
                <span class="scale-label">Sangat tidak puas</span>
                <div class="rating-number" onclick="highlight(this)">1</div>
                <div class="rating-number" onclick="highlight(this)">2</div>
                <div class="rating-number" onclick="highlight(this)">3</div>
                <div class="rating-number" onclick="highlight(this)">4</div>
                <div class="rating-number" onclick="highlight(this)">5</div>
                <span class="scale-label">Sangat puas</span>
            </div>
        </div>

        <a class="btn-submit" href="/Survey/OnlineNext">Berikutnya</a>
    </div>

    <script>
        function highlight(el) {
            const siblings = el.parentElement.querySelectorAll('.rating-number');
            siblings.forEach(s => s.classList.remove('selected'));
            el.classList.add('selected');
        }
    </script>
</body>
</html>
