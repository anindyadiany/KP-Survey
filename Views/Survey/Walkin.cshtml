@model SurveyApp.Models.QuestionResponse
@{ Layout = null; }

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Survey Layanan IT</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="page-center">
    <div class="survey-container">
        <h1 class="survey-title">Survey Kepuasan Layanan IT</h1>

        @if (TempData["FormError"] != null)
        {
            <div class="validation-error">@TempData["FormError"]</div>
        }

        <form id="walkinForm" asp-action="SubmitWalkin" method="post" novalidate>
            <input type="hidden" name="submissionId" value="@ViewBag.SubmissionId" />
            <div id="formError" class="validation-error" style="display:none;"></div>
            
            @foreach (var q in ViewBag.Questions)
            {
                <div class="question-group">
                    <p class="question-text">@q.question_body</p>

                    @if (q.input_type == "selection")
                    {
                        @if (q.id == 10) // Layanan Select
                        {
                            <select name="serviceId" id="serviceSelect" class="styled-select" required>
                                <option selected disabled>Pilih salah satu</option>
                                @foreach (var service in ViewBag.Services) {
                                    <option value="@service.id">@service.name</option>
                                }
                            </select>
                        }
                        else if (q.id == 12) // Teknisi Select
                        {
                            <select name="technicianId" id="technicianSelect" class="styled-select" required disabled>
                                <option selected disabled>Pilih layanan terlebih dahulu</option>
                            </select>
                        }
                    }
                    else if (q.input_type == "likert_5")
                    {
                        <partial name="_LikertRating" model="q" />
                    }
                    else if (q.input_type == "nps_10")
                    {
                        <partial name="_NPSRating" model="q" />
                    }
                </div>
            }

            <button type="submit" class="btn-submit">Kirim</button>
        </form>
    </div>

    <script>
        function setRating(inputId, value, el) {
            document.getElementById(inputId).value = value;
            const siblings = el.parentElement.querySelectorAll('.rating-number');
            siblings.forEach(s => s.classList.remove('selected'));
            el.classList.add('selected');
        }

        const form = document.getElementById('walkinForm');
        const formError = document.getElementById('formError');
        const serviceSelect = document.getElementById('serviceSelect');
        const technicianSelect = document.getElementById('technicianSelect');

        if (serviceSelect && technicianSelect) {
            serviceSelect.addEventListener('change', function () {
                const serviceId = this.value;

                technicianSelect.disabled = false;
                technicianSelect.innerHTML = '<option selected disabled>Memuat teknisi...</option>';

                fetch(`/Survey/GetTechniciansByService?serviceId=${serviceId}`)
                    .then(response => response.json())
                    .then(data => {
                        technicianSelect.innerHTML = '<option selected disabled>Pilih salah satu</option>';
                        data.forEach(tech => {
                            const option = document.createElement('option');
                            option.value = tech.id;
                            option.textContent = tech.name;
                            technicianSelect.appendChild(option);
                        });
                    })
                    .catch(err => {
                        console.error('Error fetching technicians:', err);
                        technicianSelect.innerHTML = '<option selected disabled>Gagal memuat teknisi</option>';
                    });
            });
        }

        if (form) {
            form.addEventListener('submit', function (e) {
                const missing = [];

                if (serviceSelect && !serviceSelect.value) {
                    missing.push('Layanan IT');
                }

                if (technicianSelect && !technicianSelect.value) {
                    missing.push('Teknisi');
                }

                const ratingInputs = form.querySelectorAll('input[type="hidden"][name^="ratings["]');
                ratingInputs.forEach(input => {
                    if (!input.value) {
                        missing.push('Semua penilaian pertanyaan');
                    }
                });

                if (missing.length > 0) {
                    e.preventDefault();
                    formError.style.display = 'block';
                    formError.textContent = 'Harap lengkapi semua field wajib sebelum kirim.';
                    formError.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    return;
                }

                formError.style.display = 'none';
                formError.textContent = '';
            });
        }
    </script>
</body>
</html>