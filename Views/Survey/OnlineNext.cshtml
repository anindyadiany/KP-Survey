@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Survey Layanan IT - Online (Lanjutan)</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <div class="survey-container">
        <div class="progress-track" aria-hidden="true">
            <div class="progress-fill progress-fill-mid"></div>
        </div>

        <h1 class="survey-title">Survey Kepuasan Layanan IT</h1>

        <div class="question-group">
            <p class="question-text">Sistem TI dapat diandalkan dan jarang mengalami waktu henti (downtime) yang tidak terduga.</p>
            <div class="rating-scale">
                <span class="scale-label">Sangat tidak setuju</span>
                <div class="rating-number" onclick="highlight(this)">1</div>
                <div class="rating-number" onclick="highlight(this)">2</div>
                <div class="rating-number" onclick="highlight(this)">3</div>
                <div class="rating-number" onclick="highlight(this)">4</div>
                <div class="rating-number" onclick="highlight(this)">5</div>
                <span class="scale-label">Sangat setuju</span>
            </div>
        </div>

        <div class="question-group">
            <p class="question-text">Masalah TI saya diselesaikan dalam jangka waktu yang dapat diterima.</p>
            <div class="rating-scale">
                <span class="scale-label">Sangat tidak setuju</span>
                <div class="rating-number" onclick="highlight(this)">1</div>
                <div class="rating-number" onclick="highlight(this)">2</div>
                <div class="rating-number" onclick="highlight(this)">3</div>
                <div class="rating-number" onclick="highlight(this)">4</div>
                <div class="rating-number" onclick="highlight(this)">5</div>
                <span class="scale-label">Sangat setuju</span>
            </div>
        </div>

        <div class="nav-actions">
            <a class="btn-outline" href="/Survey/Online">Kembali</a>
            <a class="btn-submit" href="/Survey/OnlineTechnician">Berikutnya</a>
        </div>
    </div>

    <script>
        function highlight(el) {
            const siblings = el.parentElement.querySelectorAll('.rating-number');
            siblings.forEach(s => s.classList.remove('selected'));
            el.classList.add('selected');
        }
    </script>
</body>
</html>
