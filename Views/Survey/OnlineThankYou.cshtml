@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Terima Kasih - Online</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="page-top">

    <div class="survey-container thankyou-container">
        <div class="progress-track" aria-hidden="true">
            <div class="progress-fill progress-fill-complete"></div>
        </div>

        <h1 class="survey-title thankyou-title">Terima Kasih!</h1>

        <img class="thankyou-illustration" src="~/assets/ThankYou.svg" alt="Ilustrasi terima kasih" />

        <p class="thankyou-text">
            Survey yang Anda isi sangat berharga bagi kami untuk meningkatkan kualitas layanan kami di masa mendatang.
            Terima kasih atas waktu dan partisipasi Anda.
        </p>
    </div>

</body>
</html>
