@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Survey Layanan IT - Teknisi</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <div class="survey-container survey-container-wide">
        <div class="progress-track" aria-hidden="true">
            <div class="progress-fill progress-fill-late"></div>
        </div>

        <h1 class="survey-title">Survey Kepuasan Layanan IT</h1>

        <p class="survey-caption">
            Pilih <strong>minimal 1</strong> teknisi yang melayani Anda (boleh lebih dari satu).<br>
            Berikan penilaian 1-10 untuk masing-masing teknisi, dengan:<br>
            <strong>1 = sangat tidak mungkin merekomendasikan</strong><br>
            <strong>10 = sangat mungkin merekomendasikan</strong>
        </p>

        <div class="tech-grid">
            <article class="tech-card" role="button" tabindex="0" onclick="toggleTech(this)" onkeydown="cardKeydown(event, this)">
                <div class="tech-avatar">AS</div>
                <span class="tech-name">Nama Teknisi</span>
                <div class="tech-nps" aria-hidden="true"></div>
            </article>
            <article class="tech-card" role="button" tabindex="0" onclick="toggleTech(this)" onkeydown="cardKeydown(event, this)">
                <div class="tech-avatar">BW</div>
                <span class="tech-name">Nama Teknisi</span>
                <div class="tech-nps" aria-hidden="true"></div>
            </article>
            <article class="tech-card" role="button" tabindex="0" onclick="toggleTech(this)" onkeydown="cardKeydown(event, this)">
                <div class="tech-avatar">CN</div>
                <span class="tech-name">Nama Teknisi</span>
                <div class="tech-nps" aria-hidden="true"></div>
            </article>
            <article class="tech-card" role="button" tabindex="0" onclick="toggleTech(this)" onkeydown="cardKeydown(event, this)">
                <div class="tech-avatar">DR</div>
                <span class="tech-name">Nama Teknisi</span>
                <div class="tech-nps" aria-hidden="true"></div>
            </article>
            <article class="tech-card" role="button" tabindex="0" onclick="toggleTech(this)" onkeydown="cardKeydown(event, this)">
                <div class="tech-avatar">EK</div>
                <span class="tech-name">Nama Teknisi</span>
                <div class="tech-nps" aria-hidden="true"></div>
            </article>
            <article class="tech-card" role="button" tabindex="0" onclick="toggleTech(this)" onkeydown="cardKeydown(event, this)">
                <div class="tech-avatar">FA</div>
                <span class="tech-name">Nama Teknisi</span>
                <div class="tech-nps" aria-hidden="true"></div>
            </article>
            <article class="tech-card" role="button" tabindex="0" onclick="toggleTech(this)" onkeydown="cardKeydown(event, this)">
                <div class="tech-avatar">GH</div>
                <span class="tech-name">Nama Teknisi</span>
                <div class="tech-nps" aria-hidden="true"></div>
            </article>
            <article class="tech-card" role="button" tabindex="0" onclick="toggleTech(this)" onkeydown="cardKeydown(event, this)">
                <div class="tech-avatar">IN</div>
                <span class="tech-name">Nama Teknisi</span>
                <div class="tech-nps" aria-hidden="true"></div>
            </article>
            <article class="tech-card" role="button" tabindex="0" onclick="toggleTech(this)" onkeydown="cardKeydown(event, this)">
                <div class="tech-avatar">JR</div>
                <span class="tech-name">Nama Teknisi</span>
                <div class="tech-nps" aria-hidden="true"></div>
            </article>
        </div>

        <div class="nav-actions">
            <a class="btn-outline" href="/Survey/OnlineNext">Kembali</a>
            <a class="btn-submit" href="/Survey/OnlineFinal">Berikutnya</a>
        </div>
    </div>

    <script>
        document.querySelectorAll('.tech-nps').forEach(container => {
            for (let i = 1; i <= 10; i += 1) {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'nps-btn';
                btn.textContent = String(i);
                btn.addEventListener('click', event => selectNps(event, btn));
                container.appendChild(btn);
            }
        });

        function toggleTech(el) {
            el.classList.toggle('selected');
            const nps = el.querySelector('.tech-nps');
            if (nps) {
                nps.setAttribute('aria-hidden', String(!el.classList.contains('selected')));
            }
        }

        function cardKeydown(event, el) {
            if (event.key === 'Enter' || event.key === ' ') {
                event.preventDefault();
                toggleTech(el);
            }
        }

        function selectNps(event, button) {
            event.stopPropagation();
            const card = button.closest('.tech-card');
            card.classList.add('selected');
            const buttons = card.querySelectorAll('.nps-btn');
            buttons.forEach(btn => btn.classList.remove('selected'));
            button.classList.add('selected');
        }
    </script>
</body>
</html>
