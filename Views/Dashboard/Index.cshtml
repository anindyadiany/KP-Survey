@model IEnumerable<SurveyApp.Models.Technician>
@{
    Layout = null;
    var serviceMap = ViewBag.ServiceMap as Dictionary<int, string>;
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <title>Dashboard - Home</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .stat-card { position: relative; overflow: hidden; }
        .stat-value { font-size: 2.8rem; font-weight: 800; margin: 8px 0 4px; color: #2a408e; }
        .stat-label { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: #666; font-weight: 700; margin: 0; }
        .stat-sub { font-size: 0.8rem; color: #999; margin: 0; }
        .stat-icon { position: absolute; right: 20px; top: 50%; transform: translateY(-50%); font-size: 3rem; opacity: 0.07; color: #2a408e; }
        .rank-badge { width: 28px; height: 28px; border-radius: 8px; display: inline-flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.85rem; }
        .avatar-wrap { width: 40px; height: 40px; border-radius: 50%; overflow: hidden; flex-shrink: 0; border: 2px solid rgba(42,64,142,0.15); }
        .avatar-wrap img { width: 100%; height: 100%; object-fit: cover; }
        .avatar-fallback { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, #2a408e, #4a60ae); color: white; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 15px; flex-shrink: 0; }
        tbody tr:hover { background: rgba(42,64,142,0.03); }
    </style>
</head>
<body class="dashboard-body">

    <partial name="_Tabs" />

    <main class="dashboard-main">
        <h1 style="text-align:left; margin-top:0; margin-bottom:30px; font-size:2.2rem; color:#111; font-weight:800;">
            Home / Dashboard
        </h1>

        <!-- Stat Cards -->
        <div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:24px; margin-bottom:30px;">
            <div class="stat-card dashboard-card">
                <i class="bi bi-bar-chart-fill stat-icon"></i>
                <p class="stat-label">Total Survey Filled</p>
                <h2 class="stat-value">@ViewBag.TotalSurvey</h2>
                <p class="stat-sub">Respondents</p>
            </div>
            <div class="stat-card dashboard-card">
                <i class="bi bi-globe stat-icon"></i>
                <p class="stat-label">Online Survey</p>
                <h2 class="stat-value">@ViewBag.TotalOnline</h2>
                <p class="stat-sub">Respondents</p>
            </div>
            <div class="stat-card dashboard-card">
                <i class="bi bi-person-walking stat-icon"></i>
                <p class="stat-label">Walk-In Survey</p>
                <h2 class="stat-value">@ViewBag.TotalWalkIn</h2>
                <p class="stat-sub">Respondents</p>
            </div>
        </div>

        <!-- Chart -->
        <div class="dashboard-card" style="margin-bottom:30px;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
                <p style="font-weight:800; color:#111; font-size:1rem; margin:0;">Tingkat Kepuasan & Kualitas Servis</p>
            </div>
            <div style="height:320px;"><canvas id="satisfactionChart"></canvas></div>
        </div>

        <!-- Teknisi Table -->
        <div class="dashboard-card">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
                <p style="font-weight:800; color:#111; font-size:1rem; margin:0;">Teknisi Terbaik Bulan Ini</p>
                <a href="@Url.Action("EditTeknisi", "Dashboard")"
                   style="font-size:0.8rem; color:#2a408e; font-weight:700; text-decoration:none; display:flex; align-items:center; gap:4px;">
                    Lihat Semua <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="text-align:left; border-bottom:2px solid rgba(0,0,0,0.07); color:#888; font-size:0.78rem; text-transform:uppercase; letter-spacing:0.05em;">
                        <th style="padding:10px 14px;">Rank</th>
                        <th style="padding:10px 14px;">Teknisi</th>
                        <th style="padding:10px 14px;">Email</th>
                        <th style="padding:10px 14px;">Divisi</th>
                        <th style="padding:10px 14px; text-align:center;">NPS Score</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (tech, index) in Model.Select((v, i) => (v, i)))
                    {
                        var initials = string.IsNullOrEmpty(tech.name) ? "?" : tech.name.Substring(0, 1).ToUpper();
                        var rankColors = new[] { "#FFD700", "#C0C0C0", "#CD7F32", "#aaaaaa" };
                        var rankBg = new[] { "rgba(255,215,0,0.15)", "rgba(192,192,192,0.15)", "rgba(205,127,50,0.15)", "rgba(170,170,170,0.1)" };
                        var color = index < rankColors.Length ? rankColors[index] : "#aaa";
                        var bg = index < rankBg.Length ? rankBg[index] : "rgba(170,170,170,0.1)";
                        var divisiName = serviceMap != null && serviceMap.ContainsKey(tech.service_id) ? serviceMap[tech.service_id] : "-";

                        <tr style="border-bottom:1px solid rgba(0,0,0,0.05); transition:background 0.15s;">
                            <td style="padding:14px;">
                                <span class="rank-badge" style="background:@bg; color:@color;">
                                    @(index + 1)
                                </span>
                            </td>
                            <td style="padding:14px;">
                                <div style="display:flex; align-items:center; gap:12px;">
                                    @if (!string.IsNullOrEmpty(tech.photo_path))
                                    {
                                        <div class="avatar-wrap">
                                            <img src="~/assets/@tech.photo_path"
                                                 onerror="this.parentElement.style.display='none'; this.parentElement.nextElementSibling.style.display='flex';"
                                                 alt="@tech.name" />
                                        </div>
                                        <div class="avatar-fallback" style="display:none;">@initials</div>
                                    }
                                    else
                                    {
                                        <div class="avatar-fallback">@initials</div>
                                    }
                                    <div>
                                        <div style="font-weight:700; color:#111; font-size:0.95rem;">@tech.name</div>
                                    </div>
                                </div>
                            </td>
                            <td style="padding:14px; color:#666; font-size:0.9rem;">@tech.email</td>
                            <td style="padding:14px; color:#666; font-size:0.9rem;">@divisiName</td>
                            <td style="padding:14px; text-align:center;">
                                <span style="background:rgba(42,64,142,0.08); color:#2a408e; padding:5px 16px; border-radius:20px; font-weight:800; font-size:0.9rem; border:1px solid rgba(42,64,142,0.15);">
                                    9
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </main>

    <script>
        const ctx = document.getElementById('satisfactionChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['JAN', 'FEB', 'MAR', 'APR', 'MEI', 'JUN', 'JUL'],
                datasets: [{
                    label: 'Tingkat Kepuasan',
                    borderColor: '#2a408e',
                    backgroundColor: 'rgba(42, 64, 142, 0.08)',
                    data: [10, 25, 40, 65, 80, 95, 100],
                    tension: 0.4, fill: true, pointRadius: 5,
                    pointBackgroundColor: '#2a408e',
                    borderWidth: 2.5
                }, {
                    label: 'Kepuasan Servis',
                    borderColor: '#e74c3c',
                    backgroundColor: 'rgba(231, 76, 60, 0.08)',
                    data: [55, 15, 35, 55, 40, 15, 40],
                    tension: 0.4, fill: true, pointRadius: 5,
                    pointBackgroundColor: '#e74c3c',
                    borderWidth: 2.5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top', align: 'end',
                        labels: { color: '#333', font: { weight: '600' }, usePointStyle: true, pointStyleWidth: 8 }
                    }
                },
                scales: {
                    y: { beginAtZero: true, max: 100, ticks: { color: '#888' }, grid: { color: 'rgba(0,0,0,0.05)' } },
                    x: { ticks: { color: '#888' }, grid: { display: false } }
                }
            }
        });
    </script>
</body>
</html>
