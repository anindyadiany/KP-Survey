@model IEnumerable<SurveyApp.Models.Technician>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <title>Dashboard - Home</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
    </style>
</head>
<body class="dashboard-body">

    <!-- <aside class="sidebar-container">
        <div class="sidebar-logo-wrapper">
            <img src="~/assets/pertaminalogo.png" style="width: 140px;" alt="Logo">
        </div>
        <nav style="width: 100%;">
            <a href="@Url.Action("Index", "Dashboard")" class="nav-item active">
                <i class="bi bi-house-door-fill"></i><span>Home</span>
            </a>
            <a href="#" class="nav-item"><i class="bi bi-pencil-square"></i><span>Edit Survey</span></a>
            <a href="#" class="nav-item"><i class="bi bi-archive"></i><span>Responses</span></a>
            <a href="#" class="nav-item"><i class="bi bi-people"></i><span>Edit Teknisi</span></a>
            <a href="#" class="nav-item"><i class="bi bi-person"></i><span>User</span></a>
        </nav>
    </aside> -->
    @* CALL THE SHARED SIDEBAR HERE *@
    <partial name="_Tabs" />

    <main class="dashboard-main">
        <h1 class="survey-title" style="text-align: left; margin-top: 0; margin-bottom: 30px; font-size: 2.2rem; color: #111;">
            Home/Dashboard
        </h1>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-bottom: 30px;">
            <div class="stat-card dashboard-card">
                <p class="stat-label" style="color: #333; font-weight: 700;">Total Survey Filled</p>
                <h2 class="stat-value" style="color: #111;">@ViewBag.TotalSurvey</h2>
                <p class="stat-sub" style="color: #444;">Respondents</p>
            </div>
            <div class="stat-card dashboard-card">
                <p class="stat-label" style="color: #333; font-weight: 700;">Total Online Survey Filled</p>
                <h2 class="stat-value" style="color: #111;">@ViewBag.TotalOnline</h2>
                <p class="stat-sub" style="color: #444;">Respondents</p>
            </div>
            <div class="stat-card dashboard-card">
                <p class="stat-label" style="color: #333; font-weight: 700;">Total Walk-In Survey Filled</p>
                <h2 class="stat-value" style="color: #111;">@ViewBag.TotalWalkIn</h2>
                <p class="stat-sub" style="color: #444;">Respondents</p>
            </div>
        </div>

        <div class="stat-card dashboard-card" style="margin-bottom: 30px;">
            <p class="stat-label" style="margin-bottom: 20px; font-weight: bold; color: #111;">Tingkat Kepuasan & Kualitas Servis</p>
            <div style="height: 340px;"><canvas id="satisfactionChart"></canvas></div>
        </div>

        <div class="stat-card dashboard-card ">
            <p class="stat-label" style="margin-bottom: 20px; font-weight: bold; color: #111;">Teknisi Terbaik Bulan Ini - Januari</p>
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="text-align: left; border-bottom: 1px solid rgba(0,0,0,0.1); color: #222; font-size: 0.85rem;">
                        <th style="padding: 12px;">Rank</th>
                        <th style="padding: 12px;">Teknisi</th>
                        <th style="padding: 12px;">Email</th>
                        <th style="padding: 12px; text-align: center;">NPS Score</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (tech, index) in Model.Select((v, i) => (v, i))) {
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.2);">
                            <td style="padding: 15px; font-weight: 600;">@(index + 1)</td>
                            <td style="padding: 15px; display: flex; align-items: center; gap: 12px;">
                                <img src="~/assets/@tech.photo_path" style="width: 38px; height: 38px; border-radius: 50%; object-fit: cover; border: 2px solid white;" onerror="this.src='/assets/default-avatar.png'">
                                <span style="font-wexaight: 600;">@tech.name</span>
                            </td>
                            <td style="padding: 15px; color: #222;">@tech.email</td>
                            <td style="padding: 15px; text-align: center;">
                                <span style="background: rgba(42, 64, 142, 0.1); color: #2a408e; padding: 6px 16px; border-radius: 20px; font-weight: bold; border: 1px solid rgba(42,64,142,0.2);">9</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </main>

    <script>
        const ctx = document.getElementById('satisfactionChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['JAN', 'FEB', 'MAR', 'APR', 'MEI', 'JUN', 'JUL'],
                datasets: [{
                    label: 'Tingkat Kepuasan', borderColor: '#2a408e', backgroundColor: 'rgba(42, 64, 142, 0.1)',
                    data: [10, 25, 40, 65, 80, 95, 100], tension: 0.4, fill: true, pointRadius: 5
                }, {
                    label: 'Kepuasan Servis', borderColor: '#d9534f', backgroundColor: 'rgba(217, 83, 79, 0.1)',
                    data: [55, 15, 35, 55, 40, 15, 40], tension: 0.4, fill: true, pointRadius: 5
                }]
            },
            options: { 
                responsive: true, 
                maintainAspectRatio: false,
                plugins: { legend: { position: 'top', align: 'end', labels: { color: '#111' } } },
                scales: { 
                    y: { beginAtZero: true, max: 100, ticks: { color: '#111' } }, 
                    x: { ticks: { color: '#111' }, grid: { display: false } } 
                }
            }
        });
    </script>
</body>
</html>

