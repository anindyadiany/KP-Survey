@model IEnumerable<SurveyApp.Models.SurveySubmission>
@{
    Layout = null;
    var tab = ViewBag.Tab as string ?? "online";
    var selectedMonth = ViewBag.SelectedMonth as int? ?? 0;
    var selectedYear = ViewBag.SelectedYear as int? ?? 0;
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <title>All Respondents</title>
</head>
<body class="dashboard-body">

    <partial name="_Tabs" />

    <main class="dashboard-main">
        <div style="display:flex; align-items:center; gap:16px; margin-bottom:28px;">
            <a href="@Url.Action(tab == "walkin" ? "WalkInResponses" : "OnlineResponses", "Dashboard", new { month = selectedMonth, year = selectedYear })"
               style="color:#2a408e; text-decoration:none; font-size:1.2rem;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 style="margin:0; font-size:2rem; font-weight:800; color:#111;">
                Respondents / @(tab == "online" ? "Online" : "Walk In")
            </h1>
        </div>

        <div class="dashboard-card">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="border-bottom:2px solid rgba(0,0,0,0.07); text-align:left; font-size:0.78rem; color:#888; text-transform:uppercase; letter-spacing:0.05em;">
                        <th style="padding:10px 14px;">#</th>
                        <th style="padding:10px 14px;">Nama</th>
                        <th style="padding:10px 14px;">Email</th>
                        <th style="padding:10px 14px;">Fungsi</th>
                        <th style="padding:10px 14px;">Waktu Submit</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (s, i) in Model.Select((s, i) => (s, i)))
                    {
                        var initials = string.IsNullOrEmpty(s.respondent_name) ? "?" : s.respondent_name.Substring(0, 1).ToUpper();
                        <tr style="border-bottom:1px solid rgba(0,0,0,0.05);">
                            <td style="padding:13px 14px; color:#888; font-size:0.85rem;">@(i + 1)</td>
                            <td style="padding:13px 14px;">
                                <div style="display:flex; align-items:center; gap:10px;">
                                    <div style="width:34px; height:34px; border-radius:50%; background:linear-gradient(135deg,#2a408e,#4a60ae); color:white; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:13px; flex-shrink:0;">
                                        @initials
                                    </div>
                                    <span style="font-weight:600; color:#111;">@(s.respondent_name ?? "-")</span>
                                </div>
                            </td>
                            <td style="padding:13px 14px; color:#666; font-size:0.9rem;">@(s.respondent_email ?? "-")</td>
                            <td style="padding:13px 14px; color:#666; font-size:0.9rem;">@(s.respondent_function ?? "-")</td>
                            <td style="padding:13px 14px; color:#888; font-size:0.85rem;">@s.submitted_at.ToString("dd MMM yyyy, HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>