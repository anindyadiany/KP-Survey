@model IEnumerable<SurveyApp.Models.Question>
@{
    Layout = null;
    var categories = Model.GroupBy(q => q.survey_categories_id);
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <title>Edit Survey - Walk In</title>
</head>
<body class="dashboard-body">

    <partial name="_Tabs" />

    <main class="dashboard-main">
        <h1 style="text-align:left; margin: 0 0 28px 0; font-size: 2rem; color: #111;">
            Edit Survey / Walk In
        </h1>

        <form method="post" action="/Dashboard/SaveSurveyWalkIn">
            @Html.AntiForgeryToken()
            @foreach (var group in categories)
            {
                var categoryTitle = group.First().SurveyCategory?.title ?? "Kategori";
                <div class="dashboard-card" style="margin-bottom: 20px;">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
                        <h2 style="font-size:1.3rem; font-weight:700; color:#111; margin:0;">
                            @categoryTitle
                        </h2>
                        <button type="button"
                                style="background:#2a408e; color:white; border:none; border-radius:10px; padding:8px 18px; font-weight:600; cursor:pointer; display:flex; align-items:center; gap:6px; font-family:inherit; font-size:15px;"
                                onclick="addQuestion(this, @group.Key)">
                            <i class="bi bi-plus-lg"></i> Tambah Pertanyaan
                        </button>
                    </div>

                    <div class="question-list" data-category="@group.Key">
                        @foreach (var question in group)
                        {
                            <div class="question-row" style="display:flex; align-items:center; gap:10px; margin-bottom:10px;">
                                <input type="hidden" name="questionIds" value="@question.id" />
                                <input type="hidden" name="questionCategoryIds" value="@question.survey_categories_id" />
                                <input type="hidden" name="questionInputTypes" value="@question.input_type" />
                                <input type="text"
                                       name="questionBodies"
                                       value="@question.question_body"
                                       style="flex:1; padding:12px 16px; border:1px solid #d9d9d9; border-radius:10px; font-size:16px; font-family:inherit; background:#f8f8f8;"
                                       placeholder="Teks pertanyaan..." />
                                <button type="button" title="Input type: @question.input_type"
                                        onclick="openTypeModal(this)"
                                        style="width:38px;height:38px;border:1.5px solid #f5a623;border-radius:9px;background:rgba(245,166,35,0.08);color:#f5a623;cursor:pointer;display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-question-circle"></i>
                                </button>
                                <button type="button" title="Hapus" onclick="removeQuestion(this)"
                                        style="width:38px;height:38px;border:1.5px solid #e74c3c;border-radius:9px;background:rgba(231,76,60,0.08);color:#e74c3c;cursor:pointer;display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Edit Teknisi card -->
            <div class="dashboard-card" style="margin-bottom:20px;">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <h2 style="font-size:1.3rem; font-weight:700; color:#111; margin:0;">Edit Teknisi</h2>
                    <a href="@Url.Action("EditTeknisi", "Dashboard")"
                       style="background:#2a408e; color:white; border:none; border-radius:10px; padding:8px 18px; font-weight:600; text-decoration:none; display:flex; align-items:center; gap:6px;">
                        <i class="bi bi-box-arrow-up-right"></i> Database
                    </a>
                </div>
            </div>

            <div id="deleted-ids"></div>

            <div style="text-align:right; margin-bottom:40px;">
                <button type="submit"
                        style="background:#2a408e; color:white; border:none; border-radius:12px; padding:12px 48px; font-size:15px; font-weight:700; cursor:pointer; font-family:inherit;">
                    Simpan
                </button>
            </div>
        </form>
    </main>

    <!-- Input Type Modal -->
    <div id="typeModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.35); z-index:999; align-items:center; justify-content:center;">
        <div style="background:white; border-radius:20px; padding:32px; width:380px; box-shadow:0 20px 60px rgba(0,0,0,0.2); position:relative;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
                <h3 style="font-size:1.2rem; font-weight:700; margin:0; font-family:inherit;">Tipe Jawaban</h3>
                <button onclick="closeTypeModal()" style="background:none; border:none; font-size:1.3rem; cursor:pointer; color:#555;">✕</button>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                <button onclick="selectType('text')"
                        style="display:flex; align-items:center; gap:10px; padding:14px 18px; border:1.5px solid #d9d9d9; border-radius:12px; background:white; font-size:15px; font-weight:600; cursor:pointer; font-family:inherit;">
                    <i class="bi bi-type" style="font-size:1.1rem;"></i> Teks
                </button>
                <button onclick="selectType('selection')"
                        style="display:flex; align-items:center; gap:10px; padding:14px 18px; border:1.5px solid #d9d9d9; border-radius:12px; background:white; font-size:15px; font-weight:600; cursor:pointer; font-family:inherit;">
                    <i class="bi bi-chevron-down" style="font-size:1.1rem;"></i> Dropdown
                </button>
                <button onclick="selectType('nps_10')"
                        style="display:flex; align-items:center; gap:10px; padding:14px 18px; border:1.5px solid #d9d9d9; border-radius:12px; background:white; font-size:15px; font-weight:600; cursor:pointer; font-family:inherit;">
                    <i class="bi bi-star" style="font-size:1.1rem;"></i> Skala NPS
                </button>
                <button onclick="selectType('likert_5')"
                        style="display:flex; align-items:center; gap:10px; padding:14px 18px; border:1.5px solid #d9d9d9; border-radius:12px; background:white; font-size:15px; font-weight:600; cursor:pointer; font-family:inherit;">
                    <i class="bi bi-file-text" style="font-size:1.1rem;"></i> Skala Likert
                </button>
            </div>
        </div>
    </div>

    <script>
        let activeTypeBtn = null;

        function openTypeModal(btn) {
            activeTypeBtn = btn;
            const modal = document.getElementById('typeModal');
            modal.style.display = 'flex';

            const row = btn.closest('.question-row');
            const currentType = row.querySelector('input[name="questionInputTypes"]').value;
            modal.querySelectorAll('button[onclick^="selectType"]').forEach(b => {
                const t = b.getAttribute('onclick').match(/'(.+)'/)[1];
                b.style.borderColor = t === currentType ? '#2a408e' : '#d9d9d9';
                b.style.color = t === currentType ? '#2a408e' : '#111';
            });
        }

        function closeTypeModal() {
            document.getElementById('typeModal').style.display = 'none';
            activeTypeBtn = null;
        }

        function selectType(type) {
            if (!activeTypeBtn) return;
            const row = activeTypeBtn.closest('.question-row');
            row.querySelector('input[name="questionInputTypes"]').value = type;
            activeTypeBtn.title = 'Input type: ' + type;
            closeTypeModal();
        }

        document.getElementById('typeModal').addEventListener('click', function(e) {
            if (e.target === this) closeTypeModal();
        });

        function addQuestion(btn, categoryId) {
            const list = document.querySelector(`.question-list[data-category="${categoryId}"]`);
            const row = document.createElement('div');
            row.className = 'question-row';
            row.style.cssText = 'display:flex; align-items:center; gap:10px; margin-bottom:10px;';
            row.innerHTML = `
                <input type="hidden" name="questionIds" value="0" />
                <input type="hidden" name="questionCategoryIds" value="${categoryId}" />
                <input type="hidden" name="questionInputTypes" value="likert_5" />
                <input type="text" name="questionBodies" value=""
                    style="flex:1; padding:12px 16px; border:1px solid #d9d9d9; border-radius:10px; font-size:14px; font-family:inherit; background:#f8f8f8;"
                    placeholder="Teks pertanyaan baru..." />
                <button type="button" title="Input type: likert_5" onclick="openTypeModal(this)"
                    style="width:38px;height:38px;border:1.5px solid #f5a623;border-radius:9px;background:rgba(245,166,35,0.08);color:#f5a623;cursor:pointer;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-question-circle"></i>
                </button>
                <button type="button" title="Hapus" onclick="removeQuestion(this)"
                    style="width:38px;height:38px;border:1.5px solid #e74c3c;border-radius:9px;background:rgba(231,76,60,0.08);color:#e74c3c;cursor:pointer;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-trash"></i>
                </button>`;
            list.appendChild(row);
        }

        function removeQuestion(btn) {
            const row = btn.closest('.question-row');
            const idInput = row.querySelector('input[name="questionIds"]');
            if (idInput.value !== '0') {
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = 'deletedIds';
                hidden.value = idInput.value;
                document.getElementById('deleted-ids').appendChild(hidden);
            }
            row.remove();
        }
    </script>
</body>
</html>
