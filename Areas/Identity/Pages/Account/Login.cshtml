@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
    Layout = null;
}

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Survey IT</title>
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
    <style></style>
</head>
<body class="login-page">

    <div class="login-card">
        <div style="text-align:center; margin-bottom:28px;">
            <img src="/assets/pertaminalogo.png" style="width:130px; margin-bottom:16px;" alt="Logo" />
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="validation-error" role="alert" style="margin-bottom:16px;"></div>

            <div style="margin-bottom:16px;">
                <label class="login-label">Email</label>
                <input asp-for="Input.Email" class="login-input"
                       autocomplete="username" aria-required="true"
                       placeholder="nama@email.com" />
                <span asp-validation-for="Input.Email" style="color:#d9534f; font-size:12px;"></span>
            </div>

            <div style="margin-bottom:24px;">
                <label class="login-label">Password</label>
                <input asp-for="Input.Password" class="login-input" type="password"
                       autocomplete="current-password" aria-required="true"
                       placeholder="••••••••" />
                <span asp-validation-for="Input.Password" style="color:#d9534f; font-size:12px;"></span>
            </div>

            <button id="login-submit" type="submit" class="login-btn">Masuk</button>

            <div style="text-align:center; margin-top:20px; font-size:13px;">
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl"
                   style="color:#2a408e; text-decoration:none; font-weight:700;">
                    Daftar Akun Baru
                </a>
            </div>
        </form>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>
